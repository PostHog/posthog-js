# Minimum age (in minutes) before a package version can be installed
# 10080 minutes = 7 days
min-release-age=10080

# Allow specific packages that lost provenance attestation
trust-policy-exclude[]=undici-types@6.21.0
trust-policy-exclude[]=eslint-import-resolver-typescript@3.10.1
trust-policy-exclude[]=semver@6.3.1
