# Minimum age (in days) before a package version can be installed
# 7 days
min-release-age=7

# Hoisted node_modules layout so React Native's Android Gradle autolinking
# and iOS CocoaPods see a flat dependency tree without pnpm's .pnpm/ symlink
# layer. React Native's settings.gradle resolves @react-native/gradle-plugin
# at node_modules/@react-native/gradle-plugin, and CocoaPods copies headers
# from the shared react-native node_modules path — both require hoisting.
node-linker=hoisted
