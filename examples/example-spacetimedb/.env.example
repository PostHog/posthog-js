# Copy to .env.local and fill in your values.

# --- SpacetimeDB ---
SPACETIMEDB_HOST=ws://localhost:3000
SPACETIMEDB_DB_NAME=posthog-spacetimedb
VITE_SPACETIMEDB_HOST=ws://localhost:3000
VITE_SPACETIMEDB_DB_NAME=posthog-spacetimedb

# --- PostHog ---
# Project API key (publishable, starts with phc_). Used by the frontend (posthog-js)
# and the backend sidecar (posthog-node).
VITE_POSTHOG_KEY=phc_REPLACE_WITH_YOUR_PROJECT_API_KEY
VITE_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=phc_REPLACE_WITH_YOUR_PROJECT_API_KEY
POSTHOG_HOST=https://us.i.posthog.com

# Personal API key (secret, starts with phx_). Backend/sidecar only — enables LOCAL
# feature-flag evaluation in posthog-node. Never expose this to the browser or module.
POSTHOG_PERSONAL_API_KEY=phx_REPLACE_WITH_YOUR_PERSONAL_API_KEY
