# PostHog ETag Polling Test Configuration
# Copy this file to .env and fill in your values

# Your PostHog project API key (required)
POSTHOG_PROJECT_API_KEY=phc_your_project_api_key

# Your PostHog secret key for local evaluation (required)
POSTHOG_SECRET_KEY=phx_your_secret_key

# PostHog host (optional, defaults to https://us.i.posthog.com)
# POSTHOG_HOST=https://us.i.posthog.com
