{
  "name": "@ablaszkiewicz/posthog-nuxt",
  "version": "1.1.0",
  "description": "Nuxt module for Posthog 🦔",
  "repository": {
    "type": "git",
    "url": "https://github.com/PostHog/posthog-js.git",
    "directory": "packages/nuxt-config"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "nuxt prepare",
    "prepack": "nuxt-module-build build"
  },
  "dependencies": {
    "posthog-node": "workspace:*",
    "@posthog/cli": "^0.4.7",
    "@nuxt/kit": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "nuxt": "^4.1.2",
    "@nuxt/devtools": "^2.6.5",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.1.2"
  }
}
