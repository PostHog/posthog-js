{
    "name": "@posthog/rrdom",
    "version": "0.0.62",
    "license": "MIT",
    "type": "module",
    "main": "./dist/rrdom.cjs",
    "module": "./dist/rrdom.js",
    "unpkg": "./dist/rrdom.umd.cjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/rrdom.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/rrdom.cjs"
            }
        }
    },
    "files": [
        "dist",
        "package.json"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/PostHog/posthog-js.git"
    },
    "scripts": {
        "dev": "vite build --watch",
        "build": "pnpm turbo run prepublish",
        "check-types": "tsc -noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepublish": "tsc -noEmit && vite build",
        "lint": "pnpm eslint src/**/*.ts"
    },
    "devDependencies": {
        "@posthog/rrweb-types": "workspace:*",
        "@types/jsdom": "^20.0.0",
        "jsdom": "^22.1.0",
        "puppeteer": "^23.11.1",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vite-plugin-dts": "catalog:",
        "vitest": "^1.4.0"
    },
    "dependencies": {
        "@posthog/rrweb-snapshot": "workspace:*"
    }
}
