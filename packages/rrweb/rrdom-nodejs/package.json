{
  "name": "rrdom-nodejs",
  "version": "0.0.4",
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm turbo run prepublish",
    "check-types": "tsc -noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "prepublish": "tsc -noEmit && vite build",
    "lint": "pnpm eslint src/**/*.ts"
  },
  "keywords": [
    "rrweb",
    "rrdom-nodejs"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/rrdom-nodejs.umd.cjs",
  "module": "./dist/rrdom-nodejs.js",
  "unpkg": "./dist/rrdom-nodejs.umd.cjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/rrdom-nodejs.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/rrdom-nodejs.umd.cjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "devDependencies": {
    "@types/cssom": "^0.4.1",
    "@types/cssstyle": "^2.2.1",
    "@types/node": "^20.0.0",
    "@types/nwsapi": "^2.2.2",
    "compare-versions": "^4.1.4",
    "puppeteer": "^23.11.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "@posthog/rrdom": "workspace:*",
    "@posthog/rrweb-types": "workspace:*",
    "cssom": "^0.5.0",
    "cssstyle": "^2.3.0",
    "nwsapi": "2.2.0"
  }
}
