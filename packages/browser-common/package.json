{
    "name": "@posthog/browser-common",
    "version": "0.2.1",
    "description": "Internal shared browser utilities and extension primitives for PostHog Browser SDKs",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/PostHog/posthog-js.git",
        "directory": "packages/browser-common"
    },
    "sideEffects": [
        "./dist/utils/array-at-polyfill.js",
        "./dist/utils/array-at-polyfill.mjs",
        "./dist/utils/uuidv7.js",
        "./dist/utils/uuidv7.mjs"
    ],
    "files": [
        "dist",
        "README.md"
    ],
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "typesVersions": {
        "*": {
            "config": [
                "dist/config.d.ts"
            ],
            "constants": [
                "dist/constants.d.ts"
            ],
            "extension-runtime": [
                "dist/extension-runtime.d.ts"
            ],
            "utils/*": [
                "dist/utils/*.d.ts"
            ]
        }
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "import": "./dist/index.mjs"
        },
        "./config": {
            "types": "./dist/config.d.ts",
            "require": "./dist/config.js",
            "import": "./dist/config.mjs"
        },
        "./constants": {
            "types": "./dist/constants.d.ts",
            "require": "./dist/constants.js",
            "import": "./dist/constants.mjs"
        },
        "./extension-runtime": {
            "types": "./dist/extension-runtime.d.ts",
            "require": "./dist/extension-runtime.js",
            "import": "./dist/extension-runtime.mjs"
        },
        "./utils/*": {
            "types": "./dist/utils/*.d.ts",
            "require": "./dist/utils/*.js",
            "import": "./dist/utils/*.mjs"
        }
    },
    "scripts": {
        "clean": "rimraf dist",
        "lint": "eslint src tests",
        "lint:fix": "eslint src tests --fix",
        "build": "rslib build",
        "dev": "rslib build -w",
        "test:unit": "jest -c jest.config.cjs",
        "check-types": "pnpm build",
        "package": "pnpm pack --out $PACKAGE_DEST/%s.tgz"
    },
    "dependencies": {
        "@posthog/core": "workspace:^",
        "@posthog/types": "workspace:^"
    },
    "devDependencies": {
        "@posthog-tooling/tsconfig-base": "workspace:*",
        "@rslib/core": "catalog:",
        "@types/jest": "catalog:",
        "jest": "catalog:",
        "ts-jest": "catalog:",
        "typescript": "catalog:"
    }
}
