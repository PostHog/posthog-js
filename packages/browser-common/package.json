{
    "name": "@posthog/browser-common",
    "version": "0.0.0",
    "private": true,
    "description": "Shared browser extension primitives for PostHog JavaScript SDKs",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/PostHog/posthog-js.git",
        "directory": "packages/browser-common"
    },
    "type": "module",
    "sideEffects": false,
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "typesVersions": {
        "*": {
            "utils/*": [
                "src/utils/*.ts"
            ]
        }
    },
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts",
            "require": "./src/index.ts"
        },
        "./utils/*": {
            "types": "./src/utils/*.ts",
            "import": "./src/utils/*.ts",
            "require": "./src/utils/*.ts"
        }
    },
    "scripts": {
        "lint": "eslint src tests",
        "lint:fix": "eslint src tests --fix",
        "build": "tsc -p tsconfig.build.json",
        "test:unit": "jest -c jest.config.cjs",
        "check-types": "pnpm build",
        "package": "pnpm pack --out $PACKAGE_DEST/%s.tgz"
    },
    "dependencies": {
        "@posthog/core": "workspace:^",
        "tslib": "catalog:"
    },
    "devDependencies": {
        "@posthog-tooling/tsconfig-base": "workspace:*",
        "@types/jest": "catalog:",
        "jest": "catalog:",
        "ts-jest": "catalog:",
        "typescript": "^6.0.3"
    }
}
