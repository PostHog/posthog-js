{
    "name": "@posthog/browser-extensions",
    "version": "0.0.0",
    "private": true,
    "description": "Shared browser extension primitives for PostHog JavaScript SDKs",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/PostHog/posthog-js.git",
        "directory": "packages/browser-extensions"
    },
    "type": "module",
    "sideEffects": false,
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        }
    },
    "scripts": {
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "build": "tsc -p tsconfig.json --noEmit",
        "test:unit": "node --test \"src/**/*.spec.ts\"",
        "check-types": "pnpm build"
    },
    "devDependencies": {
        "@posthog-tooling/tsconfig-base": "workspace:*",
        "typescript": "^6.0.3"
    }
}
