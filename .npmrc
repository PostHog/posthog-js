# Minimum age (in minutes) before a package version can be installed
# 10080 minutes = 7 days
min-release-age=10080

# Allow undici-types@6.21.0 which lost provenance attestation
trust-policy-exclude[]=undici-types@6.21.0
trust-policy-exclude[]=eslint-import-resolver-typescript@3.10.1
trust-policy-exclude[]=semver@6.3.1
# Transitive deps from posthog-rrweb subtree that lost provenance after the
# packages were resolved upstream
trust-policy-exclude[]=@typescript-eslint/parser@5.62.0
trust-policy-exclude[]=rxjs@7.8.2
trust-policy-exclude[]=semver@5.7.2
trust-policy-exclude[]=vite@5.4.21
